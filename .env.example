SARVAM_API_KEY=your_sarvam_api_key_here
# For concurrent calls, provide multiple keys (comma-separated):
# SARVAM_API_KEYS=key1,key2,key3
OPENAI_API_KEY=your_openai_api_key_here
EXOTEL_ACCOUNT_SID=your_exotel_account_sid
EXOTEL_API_KEY=your_exotel_api_key
EXOTEL_API_TOKEN=your_exotel_api_token
EXOTEL_PHONE_NUMBER=your_exotel_phone_number
EXOTEL_APP_ID=your_exotel_app_id
WEBHOOK_URL=https://your-webhook-url/endpoint

# TTS Provider: "elevenlabs" or "sarvam" (default: sarvam)
TTS_PROVIDER=sarvam
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=u7DoEF74Zzu8FP2dxDfk

# Agent mode: "standard" (Sarvam pipeline) or "gemini_live" (Gemini audio-in/audio-out)
AGENT_MODE=gemini_live
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_TTS_MODEL=gemini-3.1-flash-live-preview
GEMINI_TTS_VOICE=Kore

# AgenSights observability (optional — leave blank to disable)
AGENSIGHTS_API_KEY=your_agensights_api_key_here
